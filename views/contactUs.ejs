              >
                <p class="nav-item" style="padding-right: 5px">REGISTER</p>
              </a>
            </td>
          </tr>
          <tr>
            <td colspan="6">
              <div class="veterinarians-box-contact">
                <h2
                  style="
                    text-align: center;
                    margin-top: 20px;
                    font-weight: bold;
                    font-size: 24px;
                  "
