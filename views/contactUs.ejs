<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/images/jpk_logo.jpg" type="image/jpeg" />
    <link rel="stylesheet" href="/css/animations.css" />
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/index.css" />
    <link rel="stylesheet" href="/css/landingPage.css" />
    <link rel="stylesheet" href="/css/contactPage.css" />
    <title>Contact Us | JPK Veterinary Clinic</title>
  </head>

  <body>
    <div class="full-height">
      <center>
        <table border="0">
          <tr>
            <td width="50%">
              <a href="/welcome" style="text-decoration: none;">
                <span class="edoc-logo">JPK VETERINARY CLINIC</span>
                <span class="edoc-logo-sub">| APPOINTMENT SYSTEM</span>
              </a>
            </td>
            <td width="4%">
              <a href="/welcome" class="non-style-link">
                <p class="nav-item">HOME</p>
              </a>
            </td>
            <td width="7%">
              <a href="/contact" class="non-style-link">
                <p class="nav-item">CONTACT US</p>
              </a>
            </td>
            <td width="5%">
              <a href="/services" class="non-style-link">
                <p class="nav-item">SERVICES</p>
              </a>
            </td>
            <td width="4%">
              <a href="/login" class="non-style-link">
                <p class="nav-item">LOGIN</p>
              </a>
            </td>
            <td width="4%">
              <a href="/login" class="non-style-link" onclick="handleRegisterClick()">
                <p class="nav-item" style="padding-right: 5px">REGISTER</p>
              </a>
            </td>
          </tr>
        </table>
        <div class="shadow-background">
          <main class="contact-us-page">
            <img src="/images/jpk_logo.jpg" alt="JPK Veterinary Clinic Logo" />
            <h1>Contact Us</h1>
            <div class="section">
              <h2>JPK Veterinary Clinic</h2>
              <p><strong>Call:</strong> (02) 8831-0031</p>
              <p>
                We hope you’ve enjoyed visiting our website and learning more about JPK Veterinary Clinic. 
                Our dedicated team is always here to answer any questions, address any concerns, 
                and assist you with scheduling your pet’s next visit! If you need more information regarding our 
                services or would like to discuss a specific treatment plan, feel free to reach out to Dr. Katalbas 
                or any of our other experienced professionals. We look forward to meeting both you and your beloved pet!
              </p>
            </div>

            <div class="veterinarian-cards">
              <div class="card veterinarian-card">
                <div class="card-image">
                  <img src="/images/profile-icon1.png" alt="Dr. Francis M. Katalbas" />
                </div>
                <p class="name">Dr. Francis M. Katalbas</p>
                <p class="contact_num"><b>Contact Number:</b> (0917)815-3121</p>
                <p class="email_address"><b>Email:</b> DOKFMK@yahoo.com.ph</p>
              </div>

              <div class="card veterinarian-card">
                <div class="card-image">
                  <img src="/images/profile-icon2.png" alt="Dr. Francisella P. Katalbas" />
                </div>
                <p class="name">Dr. Francisella P. Katalbas</p>
                <p class="contact_num"><b>Contact Number:</b> (0935)437-8742</p>
                <p class="email_address"><b>Email:</b> franskatalbas@gmail.com</p>
              </div>
              <div class="card veterinarian-card">
                <div class="card-image">
                  <img src="/images/profile-icon3.png" alt="Dr. Francisco M. Katalbas III" />
                </div>
                <p class="name">Jessica Katalbas</p>
                <p class="contact_num"><b>Contact Number:</b> (0927)634-3121</p>
                <p class="email_address"><b>Email:</b> jessicakatalbas@yahoo.com</p>
              </div>
            </div>
            <div class="section">
              <h3>Clinic Hours</h3>
              <ul>
                <li>Mon-Sat: 9:00 AM - 5:00 PM</li>
                <li>Sun: Closed</li>
                <li>House call: by appointment</li>
              </ul>
            </div>
          </main>
        </div>
      </center>
    <script>
      function handleRegisterClick() {
        localStorage.setItem("isRegisterClicked", "true");
      }
    </script>
  </body>
</html>
